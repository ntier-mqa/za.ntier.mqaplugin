					<font size="12" isBold="true"/>
					<paragraph leftIndent="8" rightIndent="8"/>
				</textElement>
				<textFieldExpression><![CDATA["4.3 Summary of Planned Employee Training Interventions for the period of "
 + ($F{fiscal_year} == null || $F{fiscal_year}.trim().isEmpty() ? "financial year" : $F{fiscal_year})
 + " (excludes Refresher, Induction and Ex-leave training)"]]></textFieldExpression>
