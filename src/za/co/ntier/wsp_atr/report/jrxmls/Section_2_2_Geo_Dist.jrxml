	<!-- Styles -->
	<style name="HdrBig" fontName="SansSerif" fontSize="12" isBold="true"/>
	<style name="HdrSmall" fontName="SansSerif" fontSize="10" isBold="true"/>

	<style name="TblHdr" fontName="SansSerif" fontSize="9" isBold="true"
