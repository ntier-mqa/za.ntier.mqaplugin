	<subDataset name="AuditDataset" uuid="b1c2d3e4-f5a6-7b8c-9d0e-1f2a3b4c5d6e">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="nTier_20260518.jrdax"/>
		<parameter name="RECORD_ID" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[SELECT 
				ZZ_AuditDate,
				ZZLegalName,
				zz_OccupationalQualification,
				zz_SkillsProgrammes,
				zz_Trade,
				zz_AssessmentCentreTTC,
				Region,
				zz_LeadAuditor
			FROM ZZ_AuditSchedule_rpt_v
			WHERE zz_allocationschedule_id = $P{RECORD_ID}
			ORDER BY ZZ_AuditDate, ZZLegalName]]>
		</queryString>
		<field name="zz_auditdate" class="java.lang.String"/>
		<field name="zzlegalname" class="java.lang.String"/>
		<field name="zz_occupationalqualification" class="java.lang.String"/>
		<field name="zz_skillsprogrammes" class="java.lang.String"/>
		<field name="zz_trade" class="java.lang.String"/>
		<field name="zz_assessmentcentrettc" class="java.lang.String"/>
		<field name="region" class="java.lang.String"/>
		<field name="zz_leadauditor" class="java.lang.String"/>
	</subDataset>
	<parameter name="RESOURCE_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="RECORD_ID" class="java.lang.Integer"/>
	<queryString>
