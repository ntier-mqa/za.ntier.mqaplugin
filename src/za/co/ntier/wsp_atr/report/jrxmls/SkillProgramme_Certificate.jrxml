		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString language="plsql">
		<![CDATA[SELECT
	TRIM(
		COALESCE(P.ZZFIRSTNAME, '') || ' ' || COALESCE(P.SURNAME, '')
	) AS SPNAME, --NAME
	P.ZZ_ID_PASSPORT_NO AS PASSPORTNO, --PASSPORT NUMBER
	QCTOSP.ZZSKILLSPROGRAMMETITLE, --TITLE
	QCTOSP.ZZSKILLSPROGRAMMECODE, --REFERENCE
	TO_CHAR(CURRENT_DATE, 'DD MON YYYY') AS DATEISSUED,
	NULL AS CERTIFICATENO, --SEQUENCIAL NUMBER
	NULL AS SIGNATURECHIEF, --ELECTRONIC
	NULL AS SIGNATURESMQA --ELECTRONIC
FROM
	ZZLEARNER SP
	JOIN ZZLEARNERQCTOSKILLSPROGRAMME QCTO ON QCTO.ZZLEARNER_ID = SP.ZZLEARNER_ID
	JOIN ZZQCTOSKILLSPROGRAMME QCTOSP ON QCTOSP.ZZQCTOSKILLSPROGRAMME_ID = QCTO.ZZQCTOSKILLSPROGRAMME_ID
	LEFT JOIN ZZQUALIFICATION Q ON Q.ZZQUALIFICATION_ID = QCTOSP.ZZQUALIFICATION_ID
	JOIN ZZPERSON P ON P.ZZPERSON_ID = SP.ZZPERSON_ID;]]>
	</queryString>
