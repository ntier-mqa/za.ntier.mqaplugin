					<paragraph leftIndent="8" rightIndent="8" spacingBefore="2" spacingAfter="2"/>
				</textElement>
				<text><![CDATA[Section 6: Non-Employees AET and Bursaries]]></text>
			</staticText>
			<textField>
				<reportElement x="0" y="36" width="1210" height="18" uuid="52d1f0a2-6e7b-4f33-9d08-ef6b4f64b302"/>
				<textElement verticalAlignment="Middle">
					<font size="12" isBold="true"/>
					<paragraph leftIndent="8" rightIndent="8"/>
				</textElement>
				<textFieldExpression><![CDATA["6.3 Skills Development Related Community Social Programmes Done in "
 + ($F{atr_year} == null || $F{atr_year}.intValue() <= 0 ? "previous financial year" : $F{atr_year}.toString())
 + " (Excluding Bursary, AET & HET)"]]></textFieldExpression>
			</textField>
		</band>
	</title>
