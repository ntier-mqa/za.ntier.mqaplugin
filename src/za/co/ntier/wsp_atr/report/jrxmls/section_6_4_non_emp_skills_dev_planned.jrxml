					<paragraph leftIndent="8" rightIndent="8"/>
				</textElement>
				<textFieldExpression><![CDATA["6.4 Skills Development Related Community Social Programme Planned in "
 + ($F{fiscal_year} == null || $F{fiscal_year}.trim().isEmpty() ? "financial year" : $F{fiscal_year})
 + " (Excluding Bursary, AET & HET)"]]></textFieldExpression>
			</textField>
		</band>
