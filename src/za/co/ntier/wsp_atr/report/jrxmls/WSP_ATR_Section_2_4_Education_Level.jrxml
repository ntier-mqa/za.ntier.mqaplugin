	<parameter name="ZZ_WSP_ATR_Report_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    COALESCE((SELECT CASE
                        WHEN NULLIF(regexp_replace(y.FiscalYear, '[^0-9]', '', 'g'), '') IS NOT NULL
                        THEN CAST(NULLIF(regexp_replace(y.FiscalYear, '[^0-9]', '', 'g'), '') AS INTEGER) - 1
                     END
              FROM ZZ_WSP_ATR_Report r2
              LEFT JOIN ZZ_WSP_ATR_Submitted s2 ON s2.ZZ_WSP_ATR_Submitted_ID = r2.ZZ_WSP_ATR_Submitted_ID
              LEFT JOIN C_Year y ON y.C_Year_ID = s2.ZZ_FinYear_ID
              WHERE r2.ZZ_WSP_ATR_Report_ID = $P{ZZ_WSP_ATR_Report_ID}), 0) AS report_year,
    COALESCE(qt.Name, 'Unknown') AS qual_name,
    COALESCE(e.ZZ_African_Male_Cnt, 0)    AS ZZ_African_Male_Cnt,
    COALESCE(e.ZZ_African_Female_Cnt, 0)  AS ZZ_African_Female_Cnt,
    COALESCE(e.ZZ_Coloured_Male_Cnt, 0)   AS ZZ_Coloured_Male_Cnt,
    COALESCE(e.ZZ_Coloured_Female_Cnt, 0) AS ZZ_Coloured_Female_Cnt,
    COALESCE(e.ZZ_Indian_Male_Cnt, 0)     AS ZZ_Indian_Male_Cnt,
    COALESCE(e.ZZ_Indian_Female_Cnt, 0)   AS ZZ_Indian_Female_Cnt,
    COALESCE(e.ZZ_White_Male_Cnt, 0)      AS ZZ_White_Male_Cnt,
    COALESCE(e.ZZ_White_Female_Cnt, 0)    AS ZZ_White_Female_Cnt,
    COALESCE(e.ZZ_Total_Male_Cnt, 0)      AS ZZ_Total_Male_Cnt,
    COALESCE(e.ZZ_Total_Female_Cnt, 0)    AS ZZ_Total_Female_Cnt,
    COALESCE(e.ZZ_Disabled_Cnt, 0)        AS ZZ_Disabled_Cnt,
    COALESCE(e.ZZ_NonSA_Cnt, 0)           AS ZZ_NonSA_Cnt,
    COALESCE(e.ZZ_Age_U35_Cnt, 0)         AS ZZ_Age_U35_Cnt,
    COALESCE(e.ZZ_Age_35_55_Cnt, 0)       AS ZZ_Age_35_55_Cnt,
    COALESCE(e.ZZ_Age_O55_Cnt, 0)         AS ZZ_Age_O55_Cnt
FROM ZZ_WSP_ATR_Summ_Ed_Level_Rep e
LEFT JOIN ZZ_Qualification_Type_Ref qt
       ON qt.ZZ_Qualification_Type_Ref_ID = e.Highest_Qualification_Type_ID
WHERE e.ZZ_WSP_ATR_Report_ID = $P{ZZ_WSP_ATR_Report_ID}
ORDER BY qt.Name]]>
	</queryString>
