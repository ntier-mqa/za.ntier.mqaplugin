	<parameter name="ZZ_WSP_ATR_Report_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    r.zz_wsp_atr_submitted_id                                      AS zz_wsp_atr_submitted_id,

    COALESCE(v.orgname, bp.name, '<Organisation Name>')           AS organisation_name,
    COALESCE(v.zz_sdl_no, bp.zz_sdl_no, '<SDL Number>')           AS sdl_number,

    COALESCE(NULLIF(bp.zzsiccode,''), '<SIC Code>')               AS sic_code,
    COALESCE(sic_rl.name, '<SIC Title>')                          AS sic_title,

    COALESCE(NULLIF(bp.name2,''), bp.name, v.orgname, '<Trading Name>') AS trading_name,

    CASE
      WHEN COALESCE(bp.zz_number_of_employees, bp.zznumberofemployeesprofile, bp.numberemployees) IS NULL THEN '<Organisation Size>'
      WHEN COALESCE(bp.zz_number_of_employees, bp.zznumberofemployeesprofile, bp.numberemployees) < 50 THEN 'Small'
      WHEN COALESCE(bp.zz_number_of_employees, bp.zznumberofemployeesprofile, bp.numberemployees) < 250 THEN 'Medium'
      ELSE 'Large'
    END                                                           AS organisation_size,

    COALESCE(NULLIF(bp.zzsubsector,''), '<Subsector>')            AS subsector,

    COALESCE(COALESCE(bp.zz_number_of_employees, bp.zznumberofemployeesprofile, bp.numberemployees)::text, '<Total Employees>')
                                                                  AS total_employees,
    COALESCE(bp.zzterminatedemployees::text, '<Employees Terminated>')
                                                                  AS employees_terminated,

    COALESCE( bl.phone, '<Organisation Tel No>') AS organisation_tel,
    COALESCE( bl.fax,   '<Organisation Fax No>') AS organisation_fax,
    COALESCE(u.email,'<Organisation Email>')            AS organisation_email,

    COALESCE(
      NULLIF(
        TRIM(CONCAT_WS(', ',
          loc.address1,
          loc.address2,
          loc.city,
          reg.name
        )), ''
      ),
      '<Organisation Physical Address>'
    )                                                             AS organisation_physical_address,
    COALESCE(NULLIF(loc.postal,''), '<Physical Code>')            AS physical_code,

    COALESCE(
      NULLIF(
        TRIM(CONCAT_WS(', ',
          loc.address1,
          loc.address2,
          loc.city,
          reg.name
        )), ''
      ),
      '<Organisation Postal Address>'
    )                                                             AS organisation_postal_address,
    COALESCE(NULLIF(loc.postal,''), '<Postal Code>')              AS postal_code,

    COALESCE(NULLIF(TRIM(CONCAT_WS(' - ', reg.name, loc.city)),''), '<Province - Municipality>')
                                                                  AS province_municipality,

    COALESCE(NULLIF(bp.zzorganisationtype,''), '<Type of Organisation>')
                                                                  AS type_of_organisation,

    COALESCE(NULLIF(bp.ZZUnionised,'N'))                           AS unionised,

    COALESCE(NULLIF(bp.description,''), '<Core Business of Organisation>')
                                                                  AS core_business,

    COALESCE(TRIM(CONCAT(v.zzfirstname, ' ', v.zzmiddlename, ' ', v.zzsurname)), '<SDF Name>')
                                                                  AS sdf_name,
    COALESCE(v.phone, '<Phone Number>')                           AS sdf_phone,
    COALESCE(v.phone2, '<Cell Number>')                           AS sdf_cell,
    COALESCE(v.email, '<Email Address>')                          AS sdf_email,
    COALESCE(v.zzsdfroletype, '<SDF Role>')                       AS sdf_role,

    COALESCE(bd.bankname, '<Bank Name>')                          AS bank_name,
    COALESCE(bd.accountno, '<Account Number>')                    AS account_number,
    COALESCE(bd.zzaccountholder, '<Account Holder>')              AS account_holder,
    COALESCE(bd.accounttype, '<Type of Account>')                 AS account_type,
    COALESCE(bd.zz_branch_name, '<Branch Name>')                  AS branch_name,
    COALESCE(bd.zz_branch_number, '<Branch Code>')                AS branch_code

FROM adempiere.zz_wsp_atr_report r
LEFT JOIN adempiere.zz_wsp_atr_submitted s
       ON s.zz_wsp_atr_submitted_id = r.zz_wsp_atr_submitted_id
LEFT JOIN adempiere.zzsdforganisation_v v
       ON v.zzsdforganisation_id = s.zzsdforganisation_id

LEFT JOIN adempiere.c_bpartner bp
       ON bp.isactive='Y'
      AND bp.c_bpartner_id = v.c_bpartner_id
      
LEFT JOIN adempiere.ad_user u
     ON bp.C_BPartner_ID = u.C_BPartner_ID

LEFT JOIN LATERAL (
    SELECT bl.*
    FROM adempiere.c_bpartner_location bl
    WHERE bl.isactive='Y'
      AND bl.c_bpartner_id = bp.c_bpartner_id
    ORDER BY bl.updated DESC
    LIMIT 1
) bl ON true

LEFT JOIN adempiere.c_location loc
       ON loc.c_location_id = bl.c_location_id
LEFT JOIN adempiere.c_region reg
       ON reg.c_region_id = loc.c_region_id

LEFT JOIN LATERAL (
    SELECT bd.*
    FROM adempiere.zzbankingdetails bd
    WHERE bd.isactive='Y'
      AND bd.zzsdforganisation_id = s.zzsdforganisation_id
    ORDER BY bd.updated DESC
    LIMIT 1
) bd ON true

LEFT JOIN adempiere.ad_reference sic_ref
       ON sic_ref.ad_reference_uu = 'cddc9d77-2c4f-4650-a8a5-58c87f72dbb4'
LEFT JOIN adempiere.ad_ref_list sic_rl
       ON sic_rl.isactive='Y'
      AND sic_rl.ad_reference_id = sic_ref.ad_reference_id
      AND sic_rl.value = bp.zzsiccode

WHERE r.zz_wsp_atr_report_id = $P{ZZ_WSP_ATR_Report_ID}]]>
	</queryString>
