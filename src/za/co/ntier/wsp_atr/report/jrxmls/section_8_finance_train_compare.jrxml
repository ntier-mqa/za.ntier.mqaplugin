	<property name="com.jaspersoft.studio.unit.rightMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnWidth" value="pixel"/>
	<style name="SectionTitle" mode="Opaque" forecolor="#000000" backcolor="#BFBFBF" hTextAlign="Center" vTextAlign="Middle" fontName="SansSerif" fontSize="18" isBold="true"/>
	<style name="SectionBar" mode="Opaque" forecolor="#000000" backcolor="#BFBFBF" hTextAlign="Left" vTextAlign="Middle" fontName="SansSerif" fontSize="12" isBold="true"/>
	<style name="CellText" vTextAlign="Middle" fontName="SansSerif" fontSize="12"/>
	<style name="CellValue" hTextAlign="Center" vTextAlign="Middle" fontName="SansSerif" fontSize="12"/>
	<parameter name="ZZ_WSP_ATR_Report_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  COALESCE(t.Row_No,0)            AS row_no,
  COALESCE(t.ZZ_Section,'')       AS zz_section,
  CASE
    WHEN COALESCE(t.ZZ_Section,'') IN ('SDS_1','SDS_1_1','SDS_1_2','SDS_1_3','SDS_1_4','SDS_1_5','SDS_1_6')
      THEN 'Skills Development Spend'
    WHEN COALESCE(t.ZZ_Section,'') IN ('SDS_2','SDS_2_1','SDS_2_2','SDS_2_3','SDS_2_4','SDS_2_5')
      THEN 'Training Offered (Excluding Refresher, Induction & Ex-Leave Training)'
    WHEN COALESCE(t.ZZ_Section,'') = 'IA'
      THEN 'Comments'
    WHEN COALESCE(t.ZZ_Section,'') IN ('IA_1','IA_2','IA_3','IA_4','IA_5','IA_6')
      THEN 'Impact Assessment Please indicate to what is the extend the WSP-ATR submission process influenced the following in your company'
    WHEN COALESCE(t.ZZ_Section,'') IN ('IA_7','IA_8')
      THEN 'Comments'
    WHEN COALESCE(t.ZZ_Section,'') = 'IA_9'
      THEN 'General Comments'
    ELSE COALESCE(t.ZZ_Section,'')
  END AS section_heading,
  COALESCE(t.ZZ_Finance_Type,'')  AS finance_type,
  COALESCE(t.ZZ_Finance_Value,'') AS finance_value
FROM ZZ_WSP_ATR_Finance_Train_Compare_Rep t
WHERE t.ZZ_WSP_ATR_Report_ID = $P{ZZ_WSP_ATR_Report_ID}
ORDER BY
  CASE
    WHEN COALESCE(t.ZZ_Section,'') IN ('SDS_1','SDS_1_1','SDS_1_2','SDS_1_3','SDS_1_4','SDS_1_5','SDS_1_6') THEN 1
    WHEN COALESCE(t.ZZ_Section,'') IN ('SDS_2','SDS_2_1','SDS_2_2','SDS_2_3','SDS_2_4','SDS_2_5') THEN 2
    WHEN COALESCE(t.ZZ_Section,'') = 'IA' THEN 3
    WHEN COALESCE(t.ZZ_Section,'') IN ('IA_1','IA_2','IA_3','IA_4','IA_5','IA_6') THEN 4
    WHEN COALESCE(t.ZZ_Section,'') IN ('IA_7','IA_8') THEN 5
    WHEN COALESCE(t.ZZ_Section,'') = 'IA_9' THEN 6
    ELSE 99
  END,
  COALESCE(t.Row_No,0),
  t.ZZ_WSP_ATR_Finance_Train_Compare_Rep_ID]]>
	</queryString>
	<field name="row_no" class="java.lang.Integer"/>
	<field name="zz_section" class="java.lang.String"/>
	<field name="section_heading" class="java.lang.String"/>
	<field name="finance_type" class="java.lang.String"/>
	<field name="finance_value" class="java.lang.String"/>
