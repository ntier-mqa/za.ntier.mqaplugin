	<parameter name="ZZLEARNERSHIP_ID" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="RECORD_ID" class="java.lang.Integer"/>
	<parameter name="RESOURCE_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString language="plsql">
		<![CDATA[SELECT
	TRIM(COALESCE(P.ZZFIRSTNAME, '') || ' ' || COALESCE(P.Surname, '')) AS LEARNERNAME, --(LEARNERNAME)
	COALESCE(P.ZZ_ID_PASSPORT_NO, P.ZZOTHERIDNO) AS LEARNERID, --(LEARNERID)
	QCTOLS.ZZLEARNERSHIPTITLE, --(LEARNERSHIPTITLE)
	Q.ZZSAQAQUALIFICATIONCODE, --(SAQA ID OF THE LINKED QUALS OF LEARNERSHIP),
	QCTOLS.ZZNQFLEVEL, --(LEVEL ON LEARNERSHIP)
	NULL AS CREDITACHIEVED,
	TO_CHAR(CURRENT_DATE, 'DD MON YYYY') AS DATEISSUED,
	NULL AS CERTIFICATENO,
	NULL AS SIGNATURECHIEF,
	NULL AS SIGNATURESMQA
FROM
	ZZLEARNER L
	JOIN ZZLEARNERQCTOLEARNERSHIP QCTO ON L.ZZLEARNER_ID = QCTO.ZZLEARNER_ID
	JOIN ZZQCTOLEARNERSHIP QCTOLS ON QCTO.ZZQCTOLEARNERSHIP_ID = QCTOLS.ZZQCTOLEARNERSHIP_ID
	JOIN ZZQUALIFICATION Q ON Q.ZZQUALIFICATION_ID = QCTOLS.ZZQUALIFICATION_ID
	JOIN ZZPERSON P ON L.ZZPERSON_ID = P.ZZPERSON_ID
WHERE L.ZZLEARNER_ID = $P{RECORD_ID}]]>
	</queryString>
