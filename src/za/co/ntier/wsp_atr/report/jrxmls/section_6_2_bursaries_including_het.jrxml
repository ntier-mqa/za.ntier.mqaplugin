	<style name="SectionTitle" mode="Opaque" forecolor="#000000" backcolor="#BFBFBF" hTextAlign="Center" vTextAlign="Middle" fontName="SansSerif" fontSize="18" isBold="true"/>
	<style name="Hdr" mode="Opaque" forecolor="#000000" backcolor="#BFBFBF" hTextAlign="Center" vTextAlign="Middle" fontName="SansSerif" fontSize="14" isBold="true"/>
	<style name="HdrSmall" mode="Opaque" forecolor="#000000" backcolor="#BFBFBF" hTextAlign="Center" vTextAlign="Middle" fontName="SansSerif" fontSize="12" isBold="true"/>
	<style name="CellText" vTextAlign="Middle" fontName="SansSerif" fontSize="12"/>
	<style name="CellNum" hTextAlign="Center" vTextAlign="Middle" fontName="SansSerif" fontSize="12"/>
	<parameter name="ZZ_WSP_ATR_Report_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    t.Row_No,
    qd.Name AS programme_name,
    st.Name AS non_emp_status,
    COALESCE(y.FiscalYear,'') AS fiscal_year,
    COALESCE(
        CASE
            WHEN NULLIF(regexp_replace(y.FiscalYear, '[^0-9]', '', 'g'), '') IS NOT NULL
            THEN CAST(NULLIF(regexp_replace(y.FiscalYear, '[^0-9]', '', 'g'), '') AS INTEGER) - 1
        END,
        0
    ) AS atr_year,
    COALESCE(t.ZZ_Total_Done,0)    AS total_done,
    COALESCE(t.ZZ_Total_Planned,0) AS total_planned
FROM ZZ_WSP_ATR_Non_Emp_Burs_Rep t
LEFT JOIN ZZ_Qualification_Type_Details_Ref qd
       ON qd.ZZ_Qualification_Type_Details_Ref_ID = t.ZZ_Learning_Programme_Done_ID
LEFT JOIN ZZ_WSP_Non_Employee_Status_Ref st
       ON st.ZZ_WSP_Non_Employee_Status_Ref_ID = t.ZZ_Non_Emp_Status_Done_ID
LEFT JOIN ZZ_WSP_ATR_Report r
       ON r.ZZ_WSP_ATR_Report_ID = t.ZZ_WSP_ATR_Report_ID
LEFT JOIN ZZ_WSP_ATR_Submitted s
       ON s.ZZ_WSP_ATR_Submitted_ID = r.ZZ_WSP_ATR_Submitted_ID
LEFT JOIN C_Year y
       ON y.C_Year_ID = s.ZZ_FinYear_ID
WHERE t.ZZ_WSP_ATR_Report_ID = $P{ZZ_WSP_ATR_Report_ID}
  AND COALESCE(t.ZZ_Report_Section,'') = '6.2'
ORDER BY t.Row_No]]>
	</queryString>
	<field name="Row_No" class="java.lang.Integer"/>
	<field name="programme_name" class="java.lang.String"/>
	<field name="non_emp_status" class="java.lang.String"/>
	<field name="fiscal_year" class="java.lang.String"/>
	<field name="atr_year" class="java.lang.Integer"/>
	<field name="total_done" class="java.math.BigDecimal"/>
	<field name="total_planned" class="java.math.BigDecimal"/>
	<variable name="Sum_Done" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{total_done}]]></variableExpression>
	</variable>
	<variable name="Sum_Planned" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{total_planned}]]></variableExpression>
	</variable>
