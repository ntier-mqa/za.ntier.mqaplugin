	<subDataset name="StatementLineDataset" uuid="12345678-1234-4321-8765-1234567890ab">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SOR_SkillsProgramme/nTier_20260619_1.jrdax"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<parameter name="RECORD_ID" class="java.lang.Integer"/>
		<queryString>
			<![CDATA[SELECT 
    bsl.Line,
    bsl.StatementLineDate,
    bsl.ValutaDate,
    bsl.Description AS Line_Description,
    bsl.StmtAmt,
    ch.Name AS Charge_Name,
    bsl.TrxAmt,
    p.DocumentNo AS PaymentNo,
    curr.ISO_Code AS Currency,
    COALESCE(bs.BeginningBalance, 0) + SUM(COALESCE(bsl.StmtAmt, 0)) OVER (
        PARTITION BY bs.C_BankStatement_ID 
        ORDER BY bsl.Line ASC 
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    ) AS RunningBalance
FROM C_BankStatement bs
LEFT JOIN C_BankStatementLine bsl ON bs.C_BankStatement_ID = bsl.C_BankStatement_ID AND bsl.IsActive = 'Y'
LEFT JOIN C_Charge ch ON bsl.C_Charge_ID = ch.C_Charge_ID
LEFT JOIN C_Payment p ON bsl.C_Payment_ID = p.C_Payment_ID
LEFT JOIN C_Currency curr ON bsl.C_Currency_ID = curr.C_Currency_ID
WHERE bs.C_BankStatement_ID = $P{RECORD_ID}
ORDER BY bsl.Line ASC]]>
		</queryString>
		<field name="line" class="java.math.BigDecimal"/>
		<field name="statementlinedate" class="java.sql.Timestamp"/>
		<field name="valutadate" class="java.sql.Timestamp"/>
		<field name="line_description" class="java.lang.String"/>
		<field name="stmtamt" class="java.math.BigDecimal"/>
		<field name="charge_name" class="java.lang.String"/>
		<field name="trxamt" class="java.math.BigDecimal"/>
		<field name="paymentno" class="java.lang.String"/>
		<field name="currency" class="java.lang.String"/>
		<field name="runningbalance" class="java.math.BigDecimal"/>
	</subDataset>
	<parameter name="RECORD_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1000000]]></defaultValueExpression>
	</parameter>
	<parameter name="RESOURCE_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
    bs.C_BankStatement_ID,
    bs.DocumentNo,
    bs.Name AS Statement_Name,
    bs.StatementDate,
    COALESCE(bs.BeginningBalance, 0) AS BeginningBalance,
    bs.EndingBalance,
    bs.StatementDifference,
    ba.Name AS Bank_Account_Name,
    ba.AccountNo AS Bank_Account_No,
    b.Name AS Bank_Name,
    c.Name AS Client_Name,
    org.Name AS Org_Name
FROM C_BankStatement bs
INNER JOIN C_BankAccount ba ON bs.C_BankAccount_ID = ba.C_BankAccount_ID
LEFT JOIN C_Bank b ON ba.C_Bank_ID = b.C_Bank_ID
INNER JOIN AD_Client c ON bs.AD_Client_ID = c.AD_Client_ID
INNER JOIN AD_Org org ON bs.AD_Org_ID = org.AD_Org_ID
WHERE bs.C_BankStatement_ID = $P{RECORD_ID}]]>
	</queryString>
	<field name="c_bankstatement_id" class="java.lang.Integer"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="statement_name" class="java.lang.String"/>
	<field name="statementdate" class="java.sql.Timestamp"/>
	<field name="beginningbalance" class="java.math.BigDecimal"/>
	<field name="endingbalance" class="java.math.BigDecimal"/>
	<field name="statementdifference" class="java.math.BigDecimal"/>
	<field name="bank_account_name" class="java.lang.String"/>
	<field name="bank_account_no" class="java.lang.String"/>
	<field name="bank_name" class="java.lang.String"/>
	<field name="client_name" class="java.lang.String"/>
	<field name="org_name" class="java.lang.String"/>
