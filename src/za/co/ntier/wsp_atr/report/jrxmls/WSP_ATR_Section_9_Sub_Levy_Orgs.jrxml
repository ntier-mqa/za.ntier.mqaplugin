	<parameter name="ZZ_WSP_ATR_Submitted_ID" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT
    COALESCE(v.orgname, bp.name, '<Sub Levy Organisation>') AS organisation_name,
    COALESCE(v.zz_sdl_no, bp.zz_sdl_no, '<SDL Number>')     AS sdl_number,
    COALESCE(NULLIF(bp.zzsiccode,''), '<SIC Code>')         AS sic_code,
    'Y'                                 AS separate_wsp_atr
FROM adempiere.zz_wsp_atr_sub_levy_orgs slo
LEFT JOIN adempiere.zzsdforganisation_v v
  ON v.zzsdforganisation_id = slo.zzsdforganisation_id
LEFT JOIN adempiere.c_bpartner bp
  ON bp.isactive = 'Y'
 AND bp.c_bpartner_id = v.c_bpartner_id
LEFT JOIN LATERAL (
    SELECT DISTINCT ON (s.zzsdforganisation_id)
           s.zz_wsp_atr_submitted_id
    FROM adempiere.zz_wsp_atr_submitted s
    WHERE s.zzsdforganisation_id = slo.zzsdforganisation_id
      AND s.isactive = 'Y'
      AND s.zz_docstatus IN ('IM','UP','QR','RE','RA','AP')
    ORDER BY s.zzsdforganisation_id, s.updated DESC, s.zz_wsp_atr_submitted_id DESC
) child_sub ON true
WHERE slo.zz_wsp_atr_submitted_id = $P{ZZ_WSP_ATR_Submitted_ID}
ORDER BY COALESCE(v.orgname, bp.name, ''),
         COALESCE(v.zz_sdl_no, bp.zz_sdl_no, '')]]>
	</queryString>
	<field name="organisation_name" class="java.lang.String"/>
	<field name="sdl_number" class="java.lang.String"/>
	<field name="sic_code" class="java.lang.String"/>
	<field name="separate_wsp_atr" class="java.lang.String"/>
